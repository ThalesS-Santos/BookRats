rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function safeIntDelta(next, prev, maxStep) {
      return next is int && prev is int && next >= prev && (next - prev) <= maxStep;
    }

    function safeStreakDelta(next, prev) {
      return next is int && prev is int && ((next == prev) || (next == prev + 1) || (next == 0));
    }

    function safeCompletedDelta(next, prev) {
      return next is int && prev is int && ((next == prev) || (next == prev + 1) || (next == prev - 1));
    }

    function getPages(data) {
      return !('total_pages_read' in data) ? 0 : 
        (data.total_pages_read is int ? data.total_pages_read : 0);
    }

    function getStreak(data) {
      return !('current_streak' in data) ? 0 : 
        (data.current_streak is int ? data.current_streak : 0);
    }

    function getCompleted(data) {
      return !('total_books_completed' in data) ? 0 : 
        (data.total_books_completed is int ? data.total_books_completed : 0);
    }

    function getClaps(data) {
      return !('total_claps_received' in data) ? 0 : 
        (data.total_claps_received is int ? data.total_claps_received : 0);
    }

    // 🛡️ `is map` (not just != null) — if a legacy/malformed doc stored
    // socialSummary as a scalar, `in` over a non-map would ERROR during rule
    // evaluation and deny every ranking update (including the self-repair).
    function getSocialPages(data) {
      return ('socialSummary' in data && data.socialSummary is map && 'totalPagesRead' in data.socialSummary) ?
        (data.socialSummary.totalPagesRead is int ? data.socialSummary.totalPagesRead : 0) : 0;
    }

    function getSocialStreak(data) {
      return ('socialSummary' in data && data.socialSummary is map && 'currentStreak' in data.socialSummary) ?
        (data.socialSummary.currentStreak is int ? data.socialSummary.currentStreak : 0) : 0;
    }

    function isRankingUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'total_pages_read',
        'current_streak',
        'total_books_completed',
        'total_claps_received',
        'socialSummary'
      ]);
    }

    function isSafeRankingUpdate() {
      return (
        safeIntDelta(getPages(request.resource.data), getPages(resource.data), 2000) &&
        safeStreakDelta(getStreak(request.resource.data), getStreak(resource.data)) &&
        safeCompletedDelta(getCompleted(request.resource.data), getCompleted(resource.data)) &&
        getClaps(request.resource.data) == getClaps(resource.data) &&
        safeIntDelta(getSocialPages(request.resource.data), getSocialPages(resource.data), 2000) &&
        safeStreakDelta(getSocialStreak(request.resource.data), getSocialStreak(resource.data))
      ) || (
        getPages(request.resource.data) == getPages(resource.data) &&
        getStreak(request.resource.data) == getStreak(resource.data) &&
        getSocialPages(request.resource.data) == getPages(request.resource.data) &&
        getSocialStreak(request.resource.data) == getStreak(request.resource.data)
      );
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && (!isRankingUpdate() || isSafeRankingUpdate());
      allow delete: if false;

      match /notifications/{notificationId} {
        allow read, update: if isOwner(userId);
        allow create: if signedIn() && request.resource.data.senderId == request.auth.uid;
        allow delete: if false;
      }

      match /readingLogs/{logId} {
        allow read, create, delete: if isOwner(userId);
        allow update: if false;
      }

      match /books/{bookId} {
        allow read: if signedIn();
        allow write: if isOwner(userId);

        match /annotations/{annotId} {
          allow read: if signedIn() && (resource.data.isPublic == true || isOwner(userId));
          allow write: if isOwner(userId);
        }
      }
    }

    match /{path=**}/annotations/{annotId} {
      allow read: if signedIn() && (resource.data.isPublic == true || request.auth.uid == resource.data.userId);
      allow create: if signedIn() && request.auth.uid == request.resource.data.userId;
      allow update: if signedIn() && (
        request.auth.uid == resource.data.userId ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']) &&
          request.resource.data.reactions.claps == resource.data.reactions.claps + 1
        ) ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replyCount']) &&
          request.resource.data.replyCount == resource.data.replyCount + 1
        )
      );
      allow delete: if signedIn() && request.auth.uid == resource.data.userId;
    }

    match /friendships/{friendshipId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.auth.uid == request.resource.data.senderId &&
        request.resource.data.senderId != request.resource.data.receiverId &&
        request.resource.data.status == 'pending';
      allow update: if signedIn() && (
        (request.auth.uid == resource.data.receiverId && request.resource.data.status in ['accepted', 'rejected']) ||
        (request.auth.uid == resource.data.senderId && request.resource.data.status == resource.data.status)
      );
      allow delete: if signedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
    }

    match /groups/{groupId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == request.resource.data.adminId;
      allow update: if signedIn() && (
        // Cenário A: O remetente é o administrador (pode alterar qualquer campo do grupo)
        request.auth.uid == resource.data.adminId ||
        // Cenário B: O remetente é um membro comum (APENAS pode se adicionar ou remover da lista de members)
        (
          request.auth.uid in resource.data.members &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
          request.resource.data.adminId == resource.data.adminId &&
          request.resource.data.name == resource.data.name &&
          request.resource.data.description == resource.data.description
        )
      );
      allow delete: if signedIn() && request.auth.uid == resource.data.adminId;

      match /messages/{messageId} {
        allow read, create: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        allow update, delete: if false;
      }
    }
  }
}
